# Copy this file to .env locally, or set these as environment variables on
# your hosting platform's dashboard. Never commit real values — .env itself
# is gitignored.

# ---------- Core server ----------
NODE_ENV=production
PORT=5000
# Only needed if you want the server to listen somewhere other than the
# production default (0.0.0.0) or the local-dev default (127.0.0.1).
# HOST=0.0.0.0

# Where the SQLite database file lives. Leave unset for local dev (defaults
# to ./data.db). In production, point this at a mounted persistent volume —
# most hosting platforms wipe the local filesystem on every deploy/restart,
# which would silently reset the database if it isn't on a volume.
# DB_PATH=/data/data.db

# Sets a known password for the seeded admin@lobanglah.sg account instead of
# a random one-time password printed to the server log on first boot.
ADMIN_SEED_PASSWORD=

# ---------- Stripe (platform fee payments: card + PayNow) ----------
# Get these from the Stripe Dashboard (dashboard.stripe.com) once your
# account is activated for live payments in Singapore. Until these are set,
# the app runs entirely in simulated-payment mode (no code changes needed to
# switch — it's gated on STRIPE_SECRET_KEY being present).
#
# 1. STRIPE_SECRET_KEY / STRIPE_PUBLISHABLE_KEY: Dashboard > Developers > API keys.
#    Use the LIVE keys (sk_live_... / pk_live_...), not test keys, once you're
#    ready to charge real money.
# 2. Dashboard > Settings > Payment methods: turn on PayNow (card is on by
#    default). No code change is needed — the app already requests Stripe's
#    automatic_payment_methods, so whatever you enable there just appears.
# 3. STRIPE_WEBHOOK_SECRET: Dashboard > Developers > Webhooks > Add endpoint,
#    pointing at https://<your-live-domain>/api/stripe/webhook, listening for
#    payment_intent.succeeded and payment_intent.payment_failed. You can only
#    get this secret after your app has a real, publicly reachable URL — so
#    it's the last of the three to set up.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ---------- Twilio WhatsApp (phone OTP verification) ----------
# Out of scope for this deployment pass — leave unset. Without these, OTP
# codes are shown directly in the signup UI instead of sent via WhatsApp
# (see the "Demo mode" note on the verify-phone screen).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# ---------- Resend (email verification) ----------
# Sign-up requires verifying BOTH phone and email. Phone uses a WhatsApp OTP
# code (above); email uses a clickable confirmation link, valid for 30
# minutes. Until these are set, the email step runs in simulated/dev mode —
# the verification link is shown directly in the signup UI instead of
# actually emailed (same fallback pattern as the WhatsApp OTP above).
#
# 1. Create a free account at resend.com.
# 2. Domains > Add Domain, then add the DNS records Resend gives you (at your
#    domain registrar) so Resend can verify you own it. This is required —
#    Resend won't send from an unverified domain.
# 3. API Keys > Create API Key: paste it into RESEND_API_KEY below.
# 4. EMAIL_FROM must be an address on that verified domain, e.g.
#    "LobangLah! <noreply@lobanglah.sg>". Using a free Gmail/Outlook address
#    here will not work.
RESEND_API_KEY=
EMAIL_FROM=
